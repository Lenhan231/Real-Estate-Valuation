FROM python:3.11-slim

WORKDIR /app

RUN pip install fastapi uvicorn

COPY app/ui/simple_api.py /app/simple_api.py

# Verify file exists
RUN ls -la /app/simple_api.py && python -m py_compile /app/simple_api.py

EXPOSE 8501

# Use shell to run with explicit error output
CMD sh -c 'echo "Starting..." >&2 && python -u /app/simple_api.py 2>&1'
