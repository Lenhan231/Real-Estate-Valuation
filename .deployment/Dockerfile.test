FROM python:3.11-slim

WORKDIR /app

RUN pip install fastapi uvicorn

COPY app/ui/simple_api.py /app/simple_api.py

# Verify file exists
RUN ls -la /app/simple_api.py && python -m py_compile /app/simple_api.py

EXPOSE 8501

# Run with unbuffered Python and full output capture
CMD ["python", "-u", "/app/simple_api.py"]
